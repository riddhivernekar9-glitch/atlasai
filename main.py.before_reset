import os
from dotenv import load_dotenv
from openai import OpenAI
from rich.console import Console

from tools.filesystem import (
    create_folder,
    list_files,
    find_files,
    preview_move_matching,
    move_matching,
)

# ---------- Setup ----------
load_dotenv()
console = Console()

SYSTEM_PROMPT = """You are AtlasAI, a local macOS assistant.

When an action is needed, respond ONLY in one of these formats:

ACTION: create_folder
PATH: <path>

ACTION: list_files
PATH: <path>

ACTION: find_files
QUERY: <text>
PATH: <path>

ACTION: preview_move_matching
QUERY: <text or *>
SOURCE: <folder>
EXT: .pdf (optional)

ACTION: move_matching
QUERY: <text or *>
SOURCE: <folder>
DEST: <folder>
EXT: .pdf (optional)
CONFIRM: YES

If it is not a tool action, reply normally in plain English.
"""

api_key = os.getenv("OPENAI_API_KEY")
client = OpenAI(api_key=api_key) if api_key else None


# ---------- Helpers ----------
def _get_value(lines, key):
    key = key.upper() + ":"
    for ln in lines:
        if ln.upper().startswith(key):
            return ln.split(":", 1)[1].strip()
    return None


def maybe_run_action(text: str):
    raw_lines = [l.strip() for l in text.splitlines() if l.strip()]
    if not raw_lines:
        return None

    if not raw_lines[0].upper().startswith("ACTION:"):
        return None

    action = raw_lines[0].split(":", 1)[1].strip().lower()
    lines = raw_lines[1:]

    if action == "create_folder":
        path = _get_value(lines, "PATH")
        return create_folder(path) if path else "❌ create_folder needs 
PATH:"

    if action == "list_files":
        path = _get_value(lines, "PATH")
        return list_files(path) if path else "❌ list_files needs PATH:"

    if action == "find_files":
        query = _get_value(lines, "QUERY")
        path = _get_value(lines, "PATH")
        if not query or not path:
            return "❌ find_files needs QUERY: and PATH:"
        return find_files(query, path)

    if action == "preview_move_matching":
        query = _get_value(lines, "QUERY") or "*"
        source = _get_value(lines, "SOURCE")
        ext = _get_value(lines, "EXT")
        if not source:
            return "❌ preview_move_matching needs SOURCE:"
        exts = [ext] if ext else None
        return preview_move_matching(query, source, exts)

    if action == "move_matching":
        query = _get_value(lines, "QUERY") or "*"
        source = _get_value(lines, "SOURCE")
        dest = _get_value(lines, "DEST")
        ext = _get_value(lines, "EXT")
        confirm = any(l.upper() == "CONFIRM: YES" for l in lines)

        if not source or not dest:
            return "❌ move_matching needs SOURCE: and DEST:"
        if not confirm:
            return "⚠️ Move requested but not confirmed (needs CONFIRM: 
YES)."

        exts = [ext] if ext else None
        return move_matching(query, source, dest, exts)

    return f"❌ Unknown ACTION: {action}"


# ---------- Main Loop ----------
def chat_loop():
    console.print("[bold green]AtlasAI is ready.[/bold green]")
    console.print("Type 'exit' to quit.\n")

    messages = [{"role": "system", "content": SYSTEM_PROMPT}]

    while True:
        user_input = console.input("[bold cyan]You[/bold cyan]> ").strip()
        if not user_input:
            continue

        if user_input.lower() in {"exit", "quit"}:
            console.print("\nGoodbye 👋")
            break

        result = maybe_run_action(user_input)
        if result is not None:
            console.print(f"[bold yellow]Action[/bold yellow]> {result}\n")
            continue

        if client is None:
            console.print("[bold red]Error[/bold red]> OPENAI_API_KEY 
missing.\n")
            continue

        messages.append({"role": "user", "content": user_input})

        try:
            resp = client.chat.completions.create(
                model="gpt-4.1-mini",
                messages=messages,
            )
            reply = resp.choices[0].message.content.strip()
        except Exception as e:
            console.print(f"[bold red]Error[/bold red]> {e}\n")
            continue

        messages.append({"role": "assistant", "content": reply})
        console.print(f"\n[bold magenta]AtlasAI[/bold magenta]> {reply}\n")


if __name__ == "__main__":
    chat_loop()

